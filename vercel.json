{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/linkedout-extension.zip",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=linkedout-extension.zip"
        },
        {
          "key": "Content-Type",
          "value": "application/zip"
        }
      ]
    }
  ]
}